# Copy this file to `.env` and fill in your values -- but only if you're
# running locally or on a VPS. If you're using the GitHub Actions deployment
# (the recommended free option), you don't need this file at all: put these
# same values into GitHub repo Secrets instead (Settings -> Secrets and
# variables -> Actions). See README.md for details.
# .env is loaded automatically by config.py via python-dotenv.

# --- Alpaca Markets (data feed only -- no trading keys needed) ---
# Free signup: https://alpaca.markets/  -> create an API key pair (paper is fine,
# data access is the same for paper & live keys).
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# --- Telegram alerting ---
# Create a bot via @BotFather in Telegram, then get your numeric chat id via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- WhatsApp alerting (via Twilio) ---
# Sign up at https://www.twilio.com -> Messaging -> Try WhatsApp (sandbox for
# testing is free; production requires an approved WhatsApp sender).
# TWILIO_WHATSAPP_FROM is Twilio's WhatsApp number, e.g. "whatsapp:+14155238886"
# TWILIO_WHATSAPP_TO is YOUR WhatsApp number, e.g. "whatsapp:+15551234567"
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_TO=

# --- Scan behavior ---
SCAN_INTERVAL_SECONDS=60

# Minimum minutes between alerts for the SAME symbol, even if the
# confluence state changes again in between (prevents flapping near a
# trigger level from spamming you). A genuinely new setup after this
# window still alerts normally.
ALERT_COOLDOWN_MINUTES=10
LOG_LEVEL=INFO

# Alpaca defaults to IEX-only data (one exchange) unless told otherwise --
# even on paid plans. If you have a subscription that includes the full
# consolidated SIP feed (e.g. Algo Trader Plus), set this to "sip" to match
# what platforms like TradingView show by default. Leave as "iex" if
# unsure -- requesting "sip" without entitlement causes 403 errors.
ALPACA_DATA_FEED=iex
